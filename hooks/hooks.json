{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"node (Get-Item $env:USERPROFILE\\.claude\\plugins\\cache\\ram-companies\\ram\\*\\hooks\\protect-generated.js)[0].FullName\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"node (Get-Item $env:USERPROFILE\\.claude\\plugins\\cache\\ram-companies\\ram\\*\\hooks\\format.js)[0].FullName\"",
            "timeout": 30,
            "statusMessage": "Linting and formatting..."
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"node (Get-Item $env:USERPROFILE\\.claude\\plugins\\cache\\ram-companies\\ram\\*\\hooks\\post-write-checks.js)[0].FullName\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"node (Get-Item $env:USERPROFILE\\.claude\\plugins\\cache\\ram-companies\\ram\\*\\hooks\\stop-check.js)[0].FullName\"",
            "timeout": 120,
            "statusMessage": "Running type-check and tests..."
          }
        ]
      }
    ]
  }
}
