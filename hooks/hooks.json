{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && node hooks/protect-generated.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && node hooks/format.js",
            "timeout": 30,
            "statusMessage": "Linting and formatting..."
          },
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && node hooks/post-write-checks.js",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && node hooks/stop-check.js",
            "timeout": 120,
            "statusMessage": "Running type-check and tests..."
          }
        ]
      }
    ]
  }
}
